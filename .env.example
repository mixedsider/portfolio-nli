# NLI Gateway bind address.
# Use 0.0.0.0 on a server so a reverse proxy can reach the Gateway.
NLI_HOST=0.0.0.0

# NLI Gateway port used by the portfolio frontend.
NLI_PORT=8787

# LM Studio OpenAI-compatible API base URL.
LM_STUDIO_BASE_URL=http://192.168.0.57:1234/v1

# LM Studio model id.
LM_STUDIO_MODEL=qwen/qwen3.5-9b

# The gateway always sends `reasoning_effort: "none"` to Chat Completions.
# It is intentionally not an environment setting; re-probe when changing models or LM Studio versions.

# Maximum wait time for LM Studio responses in milliseconds.
LM_STUDIO_TIMEOUT_MS=8000

# Maximum generated tokens and upstream response bytes accepted from LM Studio.
LM_STUDIO_MAX_TOKENS=256
LM_STUDIO_MAX_RESPONSE_BYTES=65536

# Maximum concurrent upstream model calls handled by this Gateway process.
LM_STUDIO_MAX_CONCURRENT_REQUESTS=4

# Maximum JSON request body size for /api/nli in bytes.
NLI_MAX_REQUEST_BYTES=16384

# Maximum user message length for /api/nli.
NLI_MAX_MESSAGE_LENGTH=500

# Basic per-IP rate limit window and max request count.
NLI_RATE_LIMIT_WINDOW_MS=60000
NLI_RATE_LIMIT_MAX=30
NLI_RATE_LIMIT_MAX_BUCKETS=10000

# Abort slow client requests after this many milliseconds.
NLI_REQUEST_TIMEOUT_MS=15000

# Set to true only when a trusted reverse proxy owns X-Forwarded-For.
NLI_TRUST_PROXY=false

# Comma-separated browser origins. The Gateway denies browser origins when this is empty.
NLI_ALLOWED_ORIGINS=http://127.0.0.1:4173
