{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portfolio NLI Canonical Response",
  "description": "The Gateway, not the model, produces this browser-facing response.",
  "oneOf": [
    { "$ref": "#/$defs/navigate" },
    { "$ref": "#/$defs/defineTerm" },
    { "$ref": "#/$defs/summarizeSection" },
    { "$ref": "#/$defs/introduceProfile" },
    { "$ref": "#/$defs/summarizeProject" },
    { "$ref": "#/$defs/listProjects" },
    { "$ref": "#/$defs/summarizePortfolio" },
    { "$ref": "#/$defs/listToc" },
    { "$ref": "#/$defs/listContacts" },
    { "$ref": "#/$defs/listAchievements" },
    { "$ref": "#/$defs/listSkillExperience" },
    { "$ref": "#/$defs/listCapabilities" },
    { "$ref": "#/$defs/reject" }
  ],
  "$defs": {
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "targetId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "term": { "type": "string", "minLength": 1, "maxLength": 128 },
    "message": { "type": "string", "minLength": 1, "maxLength": 500 },
    "answer": { "type": "string", "minLength": 1, "maxLength": 12000 },
    "navigate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "targetId", "message"],
      "properties": {
        "intent": { "const": "navigate" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "targetId": { "$ref": "#/$defs/targetId" },
        "message": { "$ref": "#/$defs/message" }
      }
    },
    "defineTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "term", "message", "answer", "relatedTargets"],
      "properties": {
        "intent": { "const": "define_term" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "term": { "$ref": "#/$defs/term" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" },
        "relatedTargets": { "type": "array", "maxItems": 20, "items": { "$ref": "#/$defs/targetId" } }
      }
    },
    "summarizeSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "targetId", "message", "answer"],
      "properties": {
        "intent": { "const": "summarize_section" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "targetId": { "$ref": "#/$defs/targetId" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" }
      }
    },
    "introduceProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "message", "answer"],
      "properties": {
        "intent": { "const": "introduce_profile" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" }
      }
    },
    "summarizeProject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "targetId", "message", "answer"],
      "properties": {
        "intent": { "const": "summarize_project" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "targetId": { "$ref": "#/$defs/targetId" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" }
      }
    },
    "listProjects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "message", "answer"],
      "properties": {
        "intent": { "const": "list_projects" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" }
      }
    },
    "summarizePortfolio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "message", "answer"],
      "properties": {
        "intent": { "const": "summarize_portfolio" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" }
      }
    },
    "listToc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "message", "answer"],
      "properties": {
        "intent": { "const": "list_toc" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" }
      }
    },
    "listContacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "message", "answer"],
      "properties": {
        "intent": { "const": "list_contacts" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" }
      }
    },
    "listAchievements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "message", "answer"],
      "properties": {
        "intent": { "const": "list_achievements" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" }
      }
    },
    "listSkillExperience": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "term", "message", "answer"],
      "properties": {
        "intent": { "const": "list_skill_experience" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "term": { "$ref": "#/$defs/term" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" }
      }
    },
    "listCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "message", "answer"],
      "properties": {
        "intent": { "const": "list_capabilities" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "message": { "$ref": "#/$defs/message" },
        "answer": { "$ref": "#/$defs/answer" }
      }
    },
    "reject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "confidence", "message"],
      "properties": {
        "intent": { "const": "reject_out_of_scope" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "message": { "$ref": "#/$defs/message" }
      }
    }
  }
}
