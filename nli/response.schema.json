{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portfolio NLI Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["intent", "confidence", "message"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["navigate", "define_term", "summarize_section", "reject_out_of_scope"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "targetId": {
      "type": "string",
      "description": "navigate 또는 summarize_section intent일 때만 사용합니다."
    },
    "term": {
      "type": "string",
      "description": "define_term intent일 때만 사용합니다."
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "description": "사용자에게 보여줄 짧은 한국어 응답입니다."
    },
    "answer": {
      "type": "string",
      "description": "define_term 또는 summarize_section intent일 때 제공하는 설명입니다."
    },
    "relatedTargets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "용어 설명과 관련된 포트폴리오 섹션 ID 목록입니다."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "intent": { "const": "navigate" } }
      },
      "then": {
        "required": ["targetId"]
      }
    },
    {
      "if": {
        "properties": { "intent": { "const": "define_term" } }
      },
      "then": {
        "required": ["term", "answer"]
      }
    },
    {
      "if": {
        "properties": { "intent": { "const": "summarize_section" } }
      },
      "then": {
        "required": ["targetId", "answer"]
      }
    }
  ]
}
