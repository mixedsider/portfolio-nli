{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portfolio NLI Model Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["intent", "confidence"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "navigate",
        "define_term",
        "answer_portfolio",
        "reject_out_of_scope"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "targetId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "term": { "type": "string", "minLength": 1, "maxLength": 128 },
    "answer": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "sourceIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "intent": { "const": "navigate" } } },
      "then": {
        "required": ["targetId"],
        "not": {
          "anyOf": [
            { "required": ["term"] },
            { "required": ["answer"] },
            { "required": ["sourceIds"] }
          ]
        }
      }
    },
    {
      "if": { "properties": { "intent": { "const": "define_term" } } },
      "then": {
        "required": ["term"],
        "not": {
          "anyOf": [
            { "required": ["targetId"] },
            { "required": ["answer"] },
            { "required": ["sourceIds"] }
          ]
        }
      }
    },
    {
      "if": {
        "properties": { "intent": { "const": "answer_portfolio" } },
        "required": ["intent"]
      },
      "then": {
        "required": ["answer", "sourceIds"],
        "not": {
          "anyOf": [
            { "required": ["targetId"] },
            { "required": ["term"] }
          ]
        }
      }
    },
    {
      "if": {
        "properties": { "intent": { "not": { "const": "answer_portfolio" } } },
        "required": ["intent"]
      },
      "then": {
        "not": {
          "anyOf": [
            { "required": ["answer"] },
            { "required": ["sourceIds"] }
          ]
        }
      }
    },
    {
      "if": {
        "properties": { "intent": { "const": "reject_out_of_scope" } },
        "required": ["intent"]
      },
      "then": {
        "not": {
          "anyOf": [
            { "required": ["targetId"] },
            { "required": ["term"] },
            { "required": ["answer"] },
            { "required": ["sourceIds"] }
          ]
        }
      }
    }
  ]
}
